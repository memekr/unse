# ═══════════════════════════════════════
# 운세미 (unse.me) 환경 변수
# 이 파일을 .env.local로 복사하여 사용하세요
# ═══════════════════════════════════════

# 사이트 URL (선택: Vercel 배포 시 자동 감지)
# NEXT_PUBLIC_SITE_URL=https://unse.me

# ── Google 서치콘솔 인증 (선택) ──
# NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ── 네이버 서치어드바이저 인증 (선택) ──
# NEXT_PUBLIC_NAVER_VERIFICATION=

# ═══════════════════════════════════════
# 아래는 _private/ 모듈 사용 시에만 필요합니다
# 기본 운세 기능은 아래 설정 없이도 동작합니다
# ═══════════════════════════════════════

# ── Google Analytics 4 (선택) ──
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Firebase (Google 로그인 + 결과 저장, 선택) ──
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱에서 확인
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 쿠팡파트너스 (상품 추천 광고, 선택) ──
# https://partners.coupang.com 에서 발급
# COUPANG_ACCESS_KEY=
# COUPANG_SECRET_KEY=
# COUPANG_SUB_ID=

# ── Play Store 앱 (선택) ──
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=me.unse.app

# ── Web Push (VAPID) ──
# npx web-push generate-vapid-keys --json 으로 생성
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 발신자 이메일 (VAPID subject)
VAPID_SUBJECT=mailto:admin@unse.me
