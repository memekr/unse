# 사이트 URL (Vercel 배포 시 자동 감지되나, 커스텀 도메인일 때 명시)
NEXT_PUBLIC_SITE_URL=https://unse.me

# Google Analytics 4 측정 ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# 네이버 서치어드바이저 인증 코드
NEXT_PUBLIC_NAVER_VERIFICATION=abcdef1234567890

# ── Firebase (Google 로그인 + 결과 저장) ──
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱에서 확인
# npm install firebase 필요
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 쿠팡파트너스 (상품 추천 광고) ──
# https://partners.coupang.com 에서 발급
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_SUB_ID=unse

# ── 네이버 쇼핑커넥트 (브랜드커넥트) ──
# 공개 API 없음 — 브랜드커넥트 대시보드에서 제휴 링크 발급 후
# app/api/products/route.ts의 NAVER_MANUAL_PRODUCTS에 직접 등록
# https://brandconnect.naver.com
